# --- OpenRouter ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Any OpenRouter-supported model with tool-calling.
# Geo-safe picks (don't 403 on "provider TOS violation"):
#   deepseek/deepseek-chat          (very cheap, decent, CN-hosted — default)
#   mistralai/mistral-small-3.1-24b-instruct  (EU, solid)
#   qwen/qwen-2.5-72b-instruct      (Alibaba, no geo block)
#   anthropic/claude-haiku-4.5      (best quality/price, but may geo-block some regions)
# Geo-risky (may 403 from RU/BY/IR/CN):
#   openai/gpt-4o-mini, openai/gpt-4o
#   google/gemini-2.5-flash, google/gemini-2.0-flash-001
# Full list: https://openrouter.ai/models (filter by "supports: tools")
OPENROUTER_MODEL=deepseek/deepseek-chat

# --- Groq (Speech-to-Text for Telegram voice messages) ---
# Get key: https://console.groq.com/keys
# Leave empty to disable STT entirely.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Groq-supported Whisper models (April 2026):
#   whisper-large-v3-turbo   (default — 2-3x faster, cheap, quality ~ large-v3)
#   whisper-large-v3         (best quality, slower)
#   distil-whisper-large-v3-en  (English only, fastest — do NOT use for Russian)
GROQ_STT_MODEL=whisper-large-v3-turbo

# --- STT behavior (legacy/fallback) ---
# Runtime behavior can now be changed from Telegram with /settings and /set.
# These env vars are defaults for first boot and fallback if memory/settings.json
# does not override them.
STT_ENABLED=true
# ISO-639-1 hint for Whisper. "ru" gives best Russian accuracy.
# Set empty to auto-detect.
STT_LANGUAGE=ru
# Reject voice messages longer than this, to avoid surprise bills.
STT_MAX_DURATION_SEC=300

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456789:AA-your-telegram-bot-token
# Comma-separated list of Telegram user IDs allowed to talk to the bot.
# To get your id: write to @userinfobot in Telegram.
ALLOWED_TELEGRAM_USER_IDS=123456789

# --- Agent behavior ---
# Max iterations of the tool-calling loop before forcing a final answer.
AGENT_MAX_STEPS=8
# Max messages kept in per-chat history.
HISTORY_WINDOW=30

# --- Safety ---
# Set to "true" to allow the agent to execute arbitrary shell commands.
# Leave "false" unless you know what you're doing.
ALLOW_SHELL=false

# --- Battery watcher (Termux/Android only; no-op on dev machines) ---
BATTERY_WATCH_ENABLED=true
BATTERY_LOW_THRESHOLD=20
BATTERY_POLL_INTERVAL_MS=300000
# Hysteresis: alert re-arms only when battery goes above (threshold + this).
BATTERY_HYSTERESIS=5

# --- Reminders ---
# How often the scheduler checks for due reminders (milliseconds).
# 30s is a good default. Reminders are persisted to memory/reminders.json
# and survive restarts; anything overdue fires ~1.5s after boot.
REMINDERS_POLL_INTERVAL_MS=30000

# --- Daily review (legacy/fallback) ---
# Runtime behavior can now be changed from Telegram with /settings and /set.
# These env vars are defaults for first boot and fallback if memory/settings.json
# does not override them.
# At DAILY_REVIEW_CRON the agent reads today's conversation journal, your
# long-term notes in memory/notes/, and the last few daily summaries, then
# asks the LLM for a reflective evening summary. The result is saved to
# memory/notes/summary-YYYY-MM-DD.md (so the agent sees it as long-term
# memory next day) and sent to you as a markdown file in Telegram.
DAILY_REVIEW_ENABLED=true
# 5-field POSIX cron, interpreted in DAILY_REVIEW_TZ (or system tz if empty).
#   "30 22 * * *"  — every day at 22:30
#   "0 22 * * 0-4" — Sun–Thu at 22:00 (skip Fri/Sat nights)
DAILY_REVIEW_CRON=30 22 * * *
# IANA tz name, e.g. Europe/Moscow. Empty = use system tz.
DAILY_REVIEW_TZ=
# Skip the summary if the day has fewer than this many journal entries
# (user + agent messages combined). Prevents empty-day spam.
DAILY_REVIEW_MIN_MESSAGES=3
# How many previous daily summaries to load as context for continuity.
DAILY_REVIEW_PREV_DAYS=3
# Override OPENROUTER_MODEL just for the evening review. Empty = use default.
# Recommended picks for reflective writing (run once a day, cost is tiny):
#   anthropic/claude-haiku-4.5         (best nuance in RU; may geo-block)
#   anthropic/claude-sonnet-4.5        (premium; ~0.5¢/review typical)
#   qwen/qwen-2.5-72b-instruct         (geo-safe, solid reflection)
#   deepseek/deepseek-chat             (default, fine)
DAILY_REVIEW_MODEL=

# --- Logging ---
LOG_LEVEL=info
